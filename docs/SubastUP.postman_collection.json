    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "description": "Inicia sesion. El token se guarda solo en {{token}} (script de Test). Cambia el email/pass por la cuenta que quieras (ver RESEED_Y_DATOS.md).",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@subastup.com\",\n  \"password\": \"Admin1234\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "auth": {
              "type": "noauth"
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Guarda automaticamente el token en la variable de coleccion {{token}}",
                  "try {",
                  "  const json = pm.response.json();",
                  "  if (json && json.token) {",
                  "    pm.collectionVariables.set('token', json.token);",
                  "    console.log('Token guardado. Rol:', json.usuario && json.usuario.rol);",
                  "  }",
                  "} catch (e) { console.log('Login sin token:', e); }"
                ]
              }
            }
          ]
        },
