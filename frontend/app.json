{
  "expo": {
    "name": "SubastUP",
    "slug": "subastup",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/images/Logo_SubastUP.jpeg",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./src/assets/images/banner_subastup.jpeg",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/images/Logo_SubastUP.jpeg",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.dai.subastup",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "plugins": [
      "expo-image-picker"
    ]
  }
}
