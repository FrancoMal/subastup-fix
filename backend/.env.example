# ─── Base de datos (Railway te da esta URL automáticamente) ───
DATABASE_URL="postgresql://usuario:contraseña@host:5432/subastup"

# ─── JWT ───
JWT_SECRET="cambia_esto_por_un_string_largo_y_random"
JWT_EXPIRES_IN="7d"

# ─── Servidor ───
PORT=3000
NODE_ENV=development

# ─── Cloudinary (para fotos de subastas y avatares) ───
CLOUDINARY_CLOUD_NAME="tu_cloud_name"
CLOUDINARY_API_KEY="tu_api_key"
CLOUDINARY_API_SECRET="tu_api_secret"
